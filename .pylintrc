[MAIN]
jobs=0

[FORMAT]
max-line-length=120

[MESSAGES CONTROL]
disable=
    too-many-arguments,
    too-many-branches,
    too-many-instance-attributes,
    too-many-public-methods,
    global-statement,
    fixme,
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,

[STRING]
check-quote-consistency=yes

[DESIGN]
max-args=10
max-locals=20
max-returns=10
max-branches=15
max-statements=60
